generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
}

enum OrderType {
  DINE_IN
  TAKEOUT
  DELIVERY
  PHONE
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  LINE_PAY
  TRANSFER
  OTHER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum PointTransactionType {
  EARN
  REDEEM
  ADJUST
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum DeliveryPlatform {
  FOODPANDA
  UBEREATS
  PHONE
}

enum DeliveryStatus {
  RECEIVED
  ACCEPTED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum NotificationType {
  NEW_ORDER
  STOCK_ALERT
  PICKUP_REMINDER
  SALES_TARGET
  GENERAL
}

model User {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  role          UserRole          @default(STAFF)
  passwordHash  String
  pin           String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  orders        Order[]           @relation("StaffOrders")
  attendances   StaffAttendance[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Category {
  id         Int        @id @default(autoincrement())
  name       String
  sortOrder  Int        @default(0)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  menuItems  MenuItem[]

  @@map("categories")
}

model MenuItem {
  id                Int                  @id @default(autoincrement())
  name              String
  categoryId        Int
  basePrice         Float
  cost              Float                @default(0)
  stock             Int                  @default(0)
  stockAlert        Int                  @default(5)
  isActive          Boolean              @default(true)
  timePricing       Json?
  emoji             String?
  description       String?
  imageUrl          String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  category          Category             @relation(fields: [categoryId], references: [id])
  orderItems        OrderItem[]
  menuItemAddOns    MenuItemAddOnGroup[]

  @@index([categoryId])
  @@map("menu_items")
}

model AddOnGroup {
  id              Int                  @id @default(autoincrement())
  name            String
  required        Boolean              @default(false)
  maxSelect       Int                  @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  options         AddOnOption[]
  menuItemAddOns  MenuItemAddOnGroup[]

  @@map("add_on_groups")
}

model AddOnOption {
  id        Int        @id @default(autoincrement())
  groupId   Int
  name      String
  price     Float      @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  group     AddOnGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("add_on_options")
}

model MenuItemAddOnGroup {
  menuItemId   Int
  addOnGroupId Int
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  addOnGroup   AddOnGroup @relation(fields: [addOnGroupId], references: [id], onDelete: Cascade)

  @@id([menuItemId, addOnGroupId])
  @@map("menu_item_add_on_groups")
}

model Table {
  id           Int               @id @default(autoincrement())
  number       String            @unique
  capacity     Int               @default(4)
  status       TableStatus       @default(AVAILABLE)
  qrCode       String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  orders       Order[]
  reservations Reservation[]

  @@map("tables")
}

model Member {
  id             Int                @id @default(autoincrement())
  name           String
  phone          String             @unique
  points         Int                @default(0)
  totalSpent     Float              @default(0)
  birthday       DateTime?
  isBlacklisted  Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  orders         Order[]
  pointHistory   PointTransaction[]

  @@map("members")
}

model Order {
  id              Int             @id @default(autoincrement())
  orderNumber     String          @unique
  type            OrderType
  status          OrderStatus     @default(PENDING)
  tableId         Int?
  staffId         Int?
  memberId        Int?
  subtotal        Float
  total           Float
  paymentMethod   PaymentMethod?
  note            String?
  source          String          @default("pos")
  discount        Float           @default(0)
  receivedAmount  Float           @default(0)
  changeAmount    Float           @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  table           Table?          @relation(fields: [tableId], references: [id])
  staff           User?           @relation("StaffOrders", fields: [staffId], references: [id])
  member          Member?         @relation(fields: [memberId], references: [id])
  items           OrderItem[]
  pointHistory    PointTransaction[]
  deliveryOrder   DeliveryOrder?

  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         Int             @id @default(autoincrement())
  orderId    Int
  menuItemId Int
  quantity   Int
  unitPrice  Float
  addons     Json?
  note       String?
  status     OrderItemStatus @default(PENDING)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem        @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model PointTransaction {
  id        Int                  @id @default(autoincrement())
  memberId  Int
  orderId   Int?
  points    Int
  type      PointTransactionType
  note      String?
  createdAt DateTime             @default(now())
  member    Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  order     Order?               @relation(fields: [orderId], references: [id])

  @@index([memberId])
  @@map("point_transactions")
}

model StaffAttendance {
  id        Int       @id @default(autoincrement())
  userId    Int
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("staff_attendance")
}

model Reservation {
  id          Int               @id @default(autoincrement())
  tableId     Int
  memberName  String
  phone       String
  partySize   Int
  datetime    DateTime
  note        String?
  status      ReservationStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  table       Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([datetime])
  @@map("reservations")
}

model DeliveryOrder {
  id               Int              @id @default(autoincrement())
  orderId          Int              @unique
  platform         DeliveryPlatform
  externalId       String
  deliveryAddress  String?
  status           DeliveryStatus   @default(RECEIVED)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("delivery_orders")
}

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@map("notifications")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId     Int
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
